{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentChat",
  "version": "1.4.1",
  "identifier": "com.zorahm.agentchat",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ui",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentChat",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "externalBin": ["binaries/agentchat-backend"],
    "category": "DeveloperTool",
    "shortDescription": "Desktop AI chat with agent loop",
    "longDescription": "Desktop application with agentic AI chat. Tauri shell, Python agent loop, LiteLLM provider abstraction, skill packages with hot-reload manifest.",
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzMDZFOTk1M0JGMTY2N0YKUldSL1p2RTdsZWtHOCtDKzUyeTNkOHVpd2pDSnUra1I2RUZBQ3JQQzdZM2oydGFUSmRuOU54Y2EK",
      "endpoints": [
        "https://github.com/Zorahm/AgentChat/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
