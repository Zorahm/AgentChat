{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentChat",
  "version": "0.1.0",
  "identifier": "com.zorahm.agentchat",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ui",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentChat",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "externalBin": ["binaries/backend"],
    "category": "DeveloperTool",
    "shortDescription": "Desktop AI chat with agent loop",
    "longDescription": "Desktop application with agentic AI chat. Tauri shell, Python agent loop, LiteLLM provider abstraction, skill packages with hot-reload manifest."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY4NzQzRDcwQjc5NTlDRUQKUldUdG5KVzNjRDEwYUsxeFd1UVFnL1hrVFc4Z0laSHpDZkEyTVBQbWFqM2FHRTFIM2wzSW5qYmsK",
      "endpoints": [
        "https://github.com/Zorahm/AgentChat/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
